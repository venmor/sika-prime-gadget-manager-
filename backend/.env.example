# Sample environment configuration for the Sika Prime Gadget Manager

# MySQL database credentials
DB_HOST=localhost
DB_USER=root
DB_PASS=password
DB_NAME=sikaprime

# Express server port
PORT=3000

# Session and authentication
# Secret key used to sign the session cookie. In production set this to a long,
# random string and do not share it publicly.
SESSION_SECRET=changeme

# Admin credentials. The username is stored in cleartext and the password
# should be stored as a bcrypt hash. Generate a hash using a tool like
# `bcryptjs` or `openssl` to avoid storing plain text passwords. Example:
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD_HASH=$2a$10$abcdefghijklmnopqrstuv
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=